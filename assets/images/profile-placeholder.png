<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 400 400" width="400" height="400">
  <defs>
    <linearGradient id="bgGrad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" stop-color="#111638"/>
      <stop offset="100%" stop-color="#0a0e27"/>
    </linearGradient>
    <linearGradient id="circleGrad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" stop-color="#00d4ff" stop-opacity="0.3"/>
      <stop offset="100%" stop-color="#a78bfa" stop-opacity="0.3"/>
    </linearGradient>
  </defs>
  <rect width="400" height="400" fill="url(#bgGrad)" rx="20"/>
  <circle cx="200" cy="160" r="70" fill="url(#circleGrad)" stroke="#00d4ff" stroke-width="2" stroke-opacity="0.4"/>
  <path d="M120 340 C120 280, 160 250, 200 250 C240 250, 280 280, 280 340" fill="url(#circleGrad)" stroke="#a78bfa" stroke-width="2" stroke-opacity="0.4"/>
  <text x="200" y="380" text-anchor="middle" font-family="sans-serif" font-size="12" fill="#94a3b8" opacity="0.6">Upload your photo</text>
</svg>
